			roundcorner=10pt, linewidth=1pt, skipabove=12pt, innerbottommargin=9pt,
			skipbelow=2pt, linecolor=crimson, nobreak=true, backgroundcolor=surface}
		\declaretheoremstyle[headfont=\sffamily\bfseries\color{crimsonink},
			mdframed={style=mdbluebox}, headpunct={\\[3pt]}, postheadspace={0pt}]{thmbluebox}
		% Example — surface-alt panel, crimson border
		\mdfdefinestyle{mdredbox}{%
			linewidth=0.5pt, skipabove=12pt, frametitleaboveskip=5pt, frametitlebelowskip=0pt,
			skipbelow=2pt, frametitlefont=\bfseries, innertopmargin=4pt, innerbottommargin=8pt,
			nobreak=true, backgroundcolor=surfacealt, linecolor=crimson}
		\declaretheoremstyle[headfont=\bfseries\color{crimson},
			mdframed={style=mdredbox}, headpunct={\\[3pt]}, postheadspace={0pt}]{thmredbox}
		% Claim / Algorithm — left bar in ink-soft
		\mdfdefinestyle{mdgreenbox}{%
			skipabove=8pt, linewidth=2pt, rightline=false, leftline=true, topline=false,
			bottomline=false, linecolor=inksoft, backgroundcolor=bg}
		\declaretheoremstyle[headfont=\bfseries\sffamily\color{ink},
			bodyfont=\normalfont, spaceabove=2pt, spacebelow=1pt, mdframed={style=mdgreenbox},
			headpunct={ --- }]{thmgreenbox}
		% Remark — left bar in ink-soft, surface-alt bg
		\mdfdefinestyle{mdblackbox}{%
			skipabove=8pt, linewidth=3pt, rightline=false, leftline=true, topline=false,
			bottomline=false, linecolor=inksoft, backgroundcolor=surfacealt}
		\declaretheoremstyle[headfont=\bfseries, bodyfont=\normalfont\small,
			spaceabove=0pt, spacebelow=0pt, mdframed={style=mdblackbox}]{thmblackbox}
		% Solution — left bar in crimson, surface bg
		\mdfdefinestyle{mdsolbox}{%
			skipabove=8pt, linewidth=3pt, rightline=false, leftline=true, topline=false,
			bottomline=false, linecolor=crimson, backgroundcolor=surface}
		\declaretheoremstyle[headfont=\bfseries, bodyfont=\normalfont\small,
			spaceabove=0pt, spacebelow=0pt, mdframed={style=mdsolbox}]{thmsolbox}
		% Remark-lemma — left bar in crimson-ink, surface-alt bg
		\mdfdefinestyle{mdremarkbox}{%
			skipabove=8pt, linewidth=3pt, rightline=false, leftline=true, topline=false,
